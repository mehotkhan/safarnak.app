# Environment Variables Template
# Copy this file to .env.local for local development.
# Do not commit real .env or .env.local files.

# App variant controls native identity: package id, display name, scheme, and flavor.
APP_VARIANT=dev
EXPO_PUBLIC_APP_VARIANT=dev

# Optional local override. CI sets this from the semantic release calculation.
# Leave unset locally to use package.json.
# APP_VERSION=2.21.10

# React Native client values must use EXPO_PUBLIC_* because they are embedded
# in the JS bundle. Never put secrets in EXPO_PUBLIC_* variables.
EXPO_PUBLIC_GRAPHQL_URL=http://192.168.1.51:8787/graphql

# Worker-side URL used by local Wrangler and server utilities when needed.
GRAPHQL_URL=http://192.168.1.51:8787/graphql

# Mapbox Configuration
# Get your tokens from: https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN

# Mapbox Download Token (for building with native SDK)
# This is used during build time to download Mapbox SDK
# Use the SAME token as above (the public token works for downloads)
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=YOUR_MAPBOX_SECRET_DOWNLOADS_TOKEN

# App Configuration (optional native overrides)
# APP_NAME=سفرناک
# BUNDLE_IDENTIFIER=ir.mohet.safarnak
# APP_SCHEME=safarnak

# Android Version Code (optional)
# ANDROID_VERSION_CODE=11200

# Build Configuration
# NEW_ARCH=1
